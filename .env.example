# WhisperTray Configuration
# Copy this file to .env in the project root or next to WhisperTray.exe.

# Model settings
# Options: tiny, base, small, medium, large, large-v3
MODEL_SIZE=small

# Device for inference: cpu, cuda (GPU is opt-in)
DEVICE=cpu

# Compute type: int8 (CPU), float16 (CUDA)
COMPUTE_TYPE=int8

# Speech language: en, ru, or leave unset for auto-detect
# LANGUAGE=

# Decoding optimization
# 1 = greedy (fast), >1 = beam search (slower, better quality)
BEAM_SIZE=1

# false = treat each utterance independently (faster)
CONDITION_ON_PREVIOUS_TEXT=false

# VAD settings
VAD_THRESHOLD=0.5
VAD_SILENCE_DURATION_MS=500
MIN_RECORDING_DURATION=0.3
SAMPLE_RATE=16000

# CPU threading
# Limit CPU threads (sets OMP_NUM_THREADS + ONNX_NUM_THREADS). Omit for auto.
# CPU_THREADS=4

# Hotkey configuration
# Comma-separated list of keys: ctrl, shift, alt, space, a-z, 0-9
HOTKEY=ctrl,shift,space

# Behavior settings
AUTO_PASTE=true
PASTE_DELAY=0.1

# Optional overlay settings (requires pip install -e ".[ui]")
OVERLAY_ENABLED=false
OVERLAY_AUTO_HIDE_SECONDS=1.5
OVERLAY_POSITION=bottom-right
OVERLAY_SCREEN=primary
OVERLAY_DENSITY=detailed
OVERLAY_STYLE=card

# Optional tray runtime selection
# auto prefers Qt when PySide6 is installed
TRAY_BACKEND=auto
