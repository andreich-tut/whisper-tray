# WhisperTray Configuration
# Copy this file to .env and adjust settings as needed

# Transcription mode: "local" or "lmstudio"
# - local: Uses faster-whisper with downloaded model (requires GPU/CPU)
# - lmstudio: Uses LM Studio API (no local model download needed)
WHISPERTRAY_MODE=local

# LM Studio Configuration (only used when WHISPERTRAY_MODE=lmstudio)
# Default LM Studio server URL
LM_STUDIO_URL=http://localhost:1234

# Specific model to use in LM Studio (leave empty for auto-detect)
LM_STUDIO_MODEL=

# Local Model Configuration (only used when WHISPERTRAY_MODE=local)
# Options: tiny, base, small, medium, large-v3
MODEL_SIZE=large-v3

# Device for local mode: cuda, cpu
# Use 'cuda' for NVIDIA GPU acceleration (requires CUDA installed)
DEVICE=cuda

# Compute type for local mode: float16 (CUDA), int8 (CPU)
# Use 'float16' for CUDA mode with NVIDIA GPU
COMPUTE_TYPE=float16

# Hotkey Configuration
# Comma-separated list of keys: ctrl, shift, alt, space, a-z, 0-9
HOTKEY=ctrl,shift,space

# Behavior Settings
# Auto-paste transcription after copying
AUTO_PASTE=true

# Delay in seconds before pasting
PASTE_DELAY=0.1
