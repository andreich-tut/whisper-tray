# WhisperTray Configuration
# Copy this file to .env and adjust settings as needed

# Model Settings — CPU-first defaults
# Options: tiny, base, small, medium, large, large-v3
MODEL_SIZE=small

# Device for inference: cpu, cuda (GPU is opt-in)
DEVICE=cpu

# Compute type: int8 (CPU), float16 (CUDA)
COMPUTE_TYPE=int8

# Speech language: en, ru, or leave empty for auto-detect
# LANGUAGE=

# Decoding Optimization
# 1 = greedy (fast), >1 = beam search (slower, better quality)
BEAM_SIZE=1

# Condition on previous text: false = treat each utterance independently (faster)
CONDITION_ON_PREVIOUS_TEXT=false

# VAD Settings
# Voice activity detection sensitivity (0.0-1.0)
VAD_THRESHOLD=0.5

# Min silence (ms) to mark segment boundary
VAD_SILENCE_DURATION_MS=500

# Min recording length (seconds) to process
MIN_RECORDING_DURATION=0.3

# Audio sample rate (Hz)
SAMPLE_RATE=16000

# CPU Threading
# Limit CPU threads (sets OMP_NUM_THREADS + ONNX_NUM_THREADS). Omit for auto.
# CPU_THREADS=4

# Hotkey Configuration
# Comma-separated list of keys: ctrl, shift, alt, space, a-z, 0-9
HOTKEY=ctrl,shift,space

# Behavior Settings
# Auto-paste transcription after copying
AUTO_PASTE=true

# Delay in seconds before pasting
PASTE_DELAY=0.1
